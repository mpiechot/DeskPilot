{
  "manifest_version": 3,
  "name": "DeskPilot Browser Capture",
  "version": "0.1.0",
  "description": "Saves the current browser tab or window to the local DeskPilot app.",
  "permissions": ["tabs"],
  "host_permissions": ["http://127.0.0.1:17383/*"],
  "icons": {
    "16": "icons/deskpilot-16.png",
    "32": "icons/deskpilot-32.png",
    "48": "icons/deskpilot-48.png",
    "128": "icons/deskpilot-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/deskpilot-16.png",
      "32": "icons/deskpilot-32.png",
      "48": "icons/deskpilot-48.png",
      "128": "icons/deskpilot-128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Save to DeskPilot"
  }
}
